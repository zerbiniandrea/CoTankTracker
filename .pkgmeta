package-as: CoTankTracker

enable-nolib-creation: no

externals:
  libs/oUF:
    url: https://github.com/oUF-wow/oUF.git
    tag: latest

tools-used:
  - ouf

ignore:
  - assets
  - .github
  - .gitignore
  - .luacheckrc
  - .luarc.json
  - .styluaignore
  - stylua.toml
  - Makefile
  - README.md
  - CURSEFORGE.md
